{
  "manifest_version": 3,
  "name": "Almide Highlight for GitHub",
  "description": "Syntax highlighting for .almd files on GitHub",
  "version": "0.1.0",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
